# PostgreSQL connection (matches docker-compose.yml)
DATABASE_URL="postgresql://reloop:reloop@localhost:5432/reloop?schema=public"

# Secret used to sign auth session JWTs (use a long random string in production)
AUTH_JWT_SECRET="change-me-to-a-long-random-string"

# DEPRECATED as a global gate. Machine event ingestion now uses a PER-MACHINE
# secret + HMAC-signed requests (see Machine.ingestSecret, provisioned by superadmin).
# The Python simulator reads this only as a convenience default for --secret.
MACHINE_INGEST_SECRET=""

# Public app name shown in the UI
NEXT_PUBLIC_APP_NAME="Smart Waste Bank Pangandaran"

# Base URL used by the simulator and QR display payloads
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
