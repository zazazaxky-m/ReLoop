# PostgreSQL connection (database is inside Docker network)
# When running within Docker Compose, the database host is "db"
DATABASE_URL="postgresql://reloop:reloop@db:5432/reloop?schema=public"

# Database Credentials
POSTGRES_USER="reloop"
POSTGRES_PASSWORD="reloop-change-me-in-production"
POSTGRES_DB="reloop"

# Secret used to sign auth session JWTs (change to a long random string in production)
AUTH_JWT_SECRET="change-me-to-a-long-random-string"

# Public app name shown in the UI
NEXT_PUBLIC_APP_NAME="ReLoop"

# Base URL used by the simulator and QR display payloads
# Change this to your production domain (e.g. https://reloop.id)
NEXT_PUBLIC_BASE_URL="http://localhost:8080"

# Realtime WebSocket configurations
REALTIME_INTERNAL_SECRET="change-me-realtime-internal-secret"
# REALTIME_PUBLISH_URL is internal, so it points to the "realtime" container name inside Docker
REALTIME_PUBLISH_URL="http://realtime:3001/publish"

# WebSocket connection URL for clients
# Since Nginx routes /ws internally to the realtime service, clients can connect directly
# through the main HTTP(S) URL.
# For local testing/non-SSL VPS: ws://localhost:8080/ws (or ws://<VPS-IP>:8080/ws)
# For production (SSL/HTTPS): wss://yourdomain.com/ws
NEXT_PUBLIC_REALTIME_WS_URL="ws://localhost:8080/ws"
